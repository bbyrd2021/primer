# Server-side key is NOT required — users supply their own key via the UI (BYOK).
# Set this only for local development convenience if desired.
ANTHROPIC_API_KEY=sk-ant-...optional-for-local-dev...

ENVIRONMENT=development
LOG_LEVEL=INFO

# Secret mixed into API-key hashes before storing on disk.
# Without this, someone who reads cards_db/ could confirm whether a
# known key belongs to a session by re-running the hash algorithm.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
USER_ID_PEPPER=
